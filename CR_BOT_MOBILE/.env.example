# CR_BOT Mobile — Environment Variables
# Copy this file to .env before building.

# License key for the CR_BOT proxy (validates API access)
CRBOT_LICENSE_KEY=CRBOT-BETA-0001-WSLO

# Google OAuth2 Client ID (from Google Cloud Console)
# Required for Gmail send feature
# Setup: https://console.cloud.google.com/ → APIs & Services → Credentials → OAuth 2.0 Client ID
GOOGLE_CLIENT_ID=

# Proxy URL override (defaults to https://crbot-proxy.wslo.ai)
# CRBOT_PROXY_URL=https://crbot-proxy.wslo.ai
